Sub ProtectWorkbook()
    ' Protect workbook structure while allowing VBA
    ThisWorkbook.Protect Password:="ENTax2024", Structure:=True, Windows:=False
    
    ' Protect individual sheets
    Dim ws As Worksheet
    For Each ws In ThisWorkbook.Worksheets
        If ws.Name = "Input Data" Or ws.Name = "Payment Tracker" Then
            ' Allow editing in input areas only
            ws.Protect Password:="ENTax2024", _
                      DrawingObjects:=False, _
                      Contents:=True, _
                      Scenarios:=True, _
                      UserInterfaceOnly:=True, _
                      AllowFormattingCells:=False, _
                      AllowInsertingRows:=False, _
                      AllowDeletingRows:=False
        Else
            ' Fully protect calculation and output sheets
            ws.Protect Password:="ENTax2024", _
                      DrawingObjects:=True, _
                      Contents:=True, _
                      Scenarios:=True, _
                      UserInterfaceOnly:=True
        End If
    Next ws
End Sub

Sub BackupData()
    ' Create backup of user data
    Dim BackupPath As String
    Dim BackupName As String
    
    BackupPath = ThisWorkbook.Path & "\Backups\"
    BackupName = "QuarterlyTax_Backup_" & Format(Now, "yyyy-mm-dd_hh-mm") & ".xlsx"
    
    ' Create backup directory if it doesn't exist
    If Dir(BackupPath, vbDirectory) = "" Then
        MkDir BackupPath
    End If
    
    ' Save backup copy
    ThisWorkbook.SaveCopyAs BackupPath & BackupName
End Sub

