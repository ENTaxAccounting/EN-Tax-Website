    ' Update next payment info
    Call UpdateNextPaymentInfo
    
    ' Format dashboard for visual appeal
    Call FormatDashboard
    
    Application.ScreenUpdating = True
End Sub

Sub UpdatePaymentStatusIndicators()
    ' Create visual payment status indicators
    Dim wsMain As Worksheet
    Dim wsTracker As Worksheet
    Set wsMain = Worksheets("Dashboard")
    Set wsTracker = Worksheets("Payment Tracker")
    
    Dim i As Integer
    Dim Status As String
    Dim StatusCell As Range
    
    ' Update each quarter's status
    For i = 1 To 4
        Status = wsTracker.Cells(2 + i, 8).Value ' Status column
        Set StatusCell = wsMain.Cells(10 + i, 2)
        
        StatusCell.Value = "Q" & i & ": " & Status
        
        ' Color code the status
        Select Case Status
            Case "PAID"
                StatusCell.Interior.Color = RGB(144, 238, 144) ' Light green
                StatusCell.Font.Color = RGB(0, 100, 0) ' Dark green
            Case "DUE"
                StatusCell.Interior.Color = RGB(255, 255, 224) ' Light yellow
                StatusCell.Font.Color = RGB(184, 134, 11) ' Dark yellow
            Case "OVERDUE"
                StatusCell.Interior.Color = RGB(255, 182, 193) ' Light red
                StatusCell.Font.Color = RGB(139, 0, 0) ' Dark red
        End Select
        
        StatusCell.Font.Bold = True
        StatusCell.HorizontalAlignment = xlCenter
    Next i
End Sub

Sub UpdateProgressBars()
    ' Create progress bars for year completion and payment status
    Dim wsMain As Worksheet
    Set wsMain = Worksheets("Dashboard")
    
    ' Calculate year progress
    Dim YearProgress As Double
    YearProgress = (Month(Date) - 1) / 12
    
    ' Calculate payment progress
    Dim PaymentProgress As Double
    Dim TotalDue As Double
    Dim TotalPaid As Double
    
    TotalDue = Worksheets("Payment Tracker").Range("A10").Value
    TotalPaid = Worksheets("Payment Tracker").Range("A11").Value
    
    If TotalDue > 0 Then
        PaymentProgress = TotalPaid / TotalDue
    Else
        PaymentProgress = 0
    End If
    
    ' Update progress indicators
    wsMain.Range("E5").Value = "Year Progress: " & Format(YearProgress, "0%")
    wsMain.Range("E6").Value = "Payments Made: " & Format(PaymentProgress, "0%")
End Sub

Sub UpdateAlerts()
    ' Update alert messages on dashboard
    Dim wsMain As Worksheet
    Dim AlertCell As Range
    Set wsMain = Worksheets("Dashboard")
    Set AlertCell = wsMain.Range("A20")
    
    ' Clear previous alerts
    AlertCell.Clear
    AlertCell.Offset(1, 0).Clear
    AlertCell.Offset(2, 0).Clear
    
    ' Check for various alert conditions
    Call CheckSafeHarborStatus(AlertCell)
    Call CheckOverduePayments(AlertCell.Offset(1, 0))
    Call CheckUpcomingDueDates(AlertCell.Offset(2, 0))
End Sub

Sub CheckSafeHarborStatus(AlertCell As Range)
    ' Check if safe harbor requirements are met
    Dim SafeHarborMet As Boolean
    Dim SafeHarborAmount As Double
    Dim PaymentsMade As Double
    
    SafeHarborAmount = Worksheets("Calculations").Range("A21").Value
    PaymentsMade = Worksheets("Payment Tracker").Range("A11").Value
    
    SafeHarborMet = (PaymentsMade >= SafeHarborAmount)
    
    If SafeHarborMet Then
        AlertCell.Value = "✓ Safe Harbor: PROTECTED from penalties"
        AlertCell.Font.Color = RGB(0, 128, 0) ' Green
    Else
        AlertCell.Value = "⚠ Safe Harbor: NOT MET - Risk of penalties"
        AlertCell.Font.Color = RGB(255, 0, 0) ' Red
    End If
    
    AlertCell.Font.Bold = True
End Sub

