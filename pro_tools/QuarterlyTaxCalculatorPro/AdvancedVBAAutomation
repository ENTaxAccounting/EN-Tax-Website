Sub ValidateUserData()
    ' Comprehensive data validation
    Dim ErrorCount As Integer
    ErrorCount = 0
    
    ' Validate required fields
    ErrorCount = ErrorCount + ValidateRequiredFields()
    
    ' Validate numerical ranges
    ErrorCount = ErrorCount + ValidateNumericalRanges()
    
    ' Validate consistency
    ErrorCount = ErrorCount + ValidateDataConsistency()
    
    If ErrorCount > 0 Then
        MsgBox "Please review and correct " & ErrorCount & " data validation errors before proceeding.", _
               vbExclamation, APP_NAME
    End If
End Sub

Function ValidateRequiredFields() As Integer
    ' Check for required input fields
    Dim wsInput As Worksheet
    Set wsInput = Worksheets("Input Data")
    
    Dim ErrorCount As Integer
    ErrorCount = 0
    
    ' Check filing status
    If wsInput.Range("B1").Value = "" Then
        wsInput.Range("B1").Interior.Color = RGB(255, 200, 200)
        ErrorCount = ErrorCount + 1
    End If
    
    ' Check state
    If wsInput.Range("B2").Value = "" Then
        wsInput.Range("B2").Interior.Color = RGB(255, 200, 200)
        ErrorCount = ErrorCount + 1
    End If
    
    ' Check prior year tax (required for safe harbor)
    If wsInput.Range("B18").Value <= 0 Then
        wsInput.Range("B18").Interior.Color = RGB(255, 200, 200)
        ErrorCount = ErrorCount + 1
    End If
    
    ValidateRequiredFields = ErrorCount
End Function

