Sub ExportPaymentVouchers()
    ' Export Form 1040ES vouchers to PDF
    Dim wsVouchers As Worksheet
    Set wsVouchers = Worksheets("Vouchers")
    
    ' Setup print area and formatting
    Call FormatVouchersForPrint
    
    ' Export each quarter's voucher
    Dim Quarter As Integer
    For Quarter = 1 To 4
        Call ExportQuarterVoucher(Quarter)
    Next Quarter
    
    MsgBox "Payment vouchers exported successfully!", vbInformation, APP_NAME
End Sub

Sub ExportQuarterVoucher(Quarter As Integer)
    ' Export individual quarter voucher
    Dim wsVouchers As Worksheet
    Set wsVouchers = Worksheets("Vouchers")
    
    ' Set print area for specific quarter
    Dim PrintRange As String
    PrintRange = "A" & (1 + (Quarter - 1) * 10) & ":H" & (10 + (Quarter - 1) * 10)
    
    wsVouchers.PageSetup.PrintArea = PrintRange
    
    ' Export to PDF
    Dim FileName As String
    FileName = ThisWorkbook.Path & "\Q" & Quarter & "_2024_Voucher.pdf"
    
    wsVouchers.ExportAsFixedFormat Type:=xlTypePDF, _
                                  FileName:=FileName, _
                                  Quality:=xlQualityStandard, _
                                  IncludeDocProps:=True, _
                                  IgnorePrintAreas:=False
End Sub

Sub ExportTaxSummaryReport()
