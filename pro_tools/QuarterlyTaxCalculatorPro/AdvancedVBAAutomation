Private Sub Worksheet_Change(ByVal Target As Range)
    ' Handle data changes and trigger recalculations
    Application.EnableEvents = False
    
    ' If input data changed, refresh calculations
    If Target.Parent.Name = "Input Data" Then
        If Not Intersect(Target, Range("B1:E50")) Is Nothing Then
            Call RefreshAllCalculations
        End If
    End If
    
    ' If payment tracker updated, refresh dashboard
    If Target.Parent.Name = "Payment Tracker" Then
        If Not Intersect(Target, Range("F3:F6")) Is Nothing Then
            Call UpdateDashboard
        End If
    End If
    
    Application.EnableEvents = True
End Sub

