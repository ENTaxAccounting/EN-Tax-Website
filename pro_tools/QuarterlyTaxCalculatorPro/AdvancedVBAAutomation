Sub Auto_Open()
    ' Runs automatically when workbook opens
    Application.ScreenUpdating = False
    Application.EnableEvents = False
    
    ' Setup the workbook
    Call InitializeWorkbook
    Call SetupDashboard
    Call ValidateUserData
    Call UpdateDashboard
    
    ' Show welcome message
    Call ShowWelcomeMessage
    
    Application.ScreenUpdating = True
    Application.EnableEvents = True
End Sub

Sub InitializeWorkbook()
    ' Initialize workbook settings and protection
    Dim ws As Worksheet
    
    ' Set calculation mode to automatic
    Application.Calculation = xlCalculationAutomatic
    
    ' Protect all sheets except input areas
    For Each ws In ThisWorkbook.Worksheets
        If ws.Name <> "Input Data" Then
            ws.Protect Password:="ENTax2024", _
                      DrawingObjects:=False, _
                      Contents:=True, _
                      Scenarios:=True, _
                      UserInterfaceOnly:=True
        End If
    Next ws
    
    ' Enable VBA on protected sheets
    For Each ws In ThisWorkbook.Worksheets
        ws.EnableSelection = xlUnlockedCells
    Next ws
    
    ' Set current quarter and tax year
    Call DetermineCurrentQuarter
End Sub

Sub DetermineCurrentQuarter()
    ' Automatically determine current quarter based on date
    Dim CurrentMonth As Integer
    CurrentMonth = Month(Date)
    TaxYear = Year(Date)
    
    Select Case CurrentMonth
        Case 1 To 3: CurrentQuarter = 1
        Case 4 To 6: CurrentQuarter = 2
        Case 7 To 9: CurrentQuarter = 3
        Case 10 To 12: CurrentQuarter = 4
    End Select
    
    ' Adjust for tax year if in January-March
    If CurrentMonth <= 3 Then TaxYear = TaxYear - 1
End Sub

