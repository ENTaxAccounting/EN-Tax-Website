Sub RefreshAllCalculations()
    ' Master calculation refresh
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    
    ' Calculate in proper order
    Call CalculateFederalTax
    Call CalculateStateTax
    Call CalculateSelfEmploymentTax
    Call CalculateSafeHarbor
    Call CalculateQuarterlyPayments
    Call CalculatePenalties
    Call UpdatePaymentStatus
    
    ' Force recalculation
    Application.Calculate
    Application.Calculation = xlCalculationAutomatic
    Application.ScreenUpdating = True
    
    ' Update dashboard
    Call UpdateDashboard
End Sub

Function CalculateFederalTax(TaxableIncome As Double, FilingStatus As String) As Double
    ' Calculate federal income tax using 2024 tax brackets
    Dim Tax As Double
    Tax = 0
    
    Select Case FilingStatus
        Case "Single"
            If TaxableIncome <= 11000 Then
                Tax = TaxableIncome * 0.1
            ElseIf TaxableIncome <= 44725 Then
                Tax = 1100 + (TaxableIncome - 11000) * 0.12
            ElseIf TaxableIncome <= 95375 Then
                Tax = 5147 + (TaxableIncome - 44725) * 0.22
            ElseIf TaxableIncome <= 182050 Then
                Tax = 16290 + (TaxableIncome - 95375) * 0.24
            ElseIf TaxableIncome <= 231250 Then
                Tax = 37104 + (TaxableIncome - 182050) * 0.32
            ElseIf TaxableIncome <= 578125 Then
                Tax = 52832 + (TaxableIncome - 231250) * 0.35
            Else
                Tax = 174238.25 + (TaxableIncome - 578125) * 0.37
            End If
            
        Case "MFJ" ' Married Filing Jointly
            If TaxableIncome <= 22000 Then
                Tax = TaxableIncome * 0.1
            ElseIf TaxableIncome <= 89450 Then
                Tax = 2200 + (TaxableIncome - 22000) * 0.12
            ElseIf TaxableIncome <= 190750 Then
                Tax = 10294 + (TaxableIncome - 89450) * 0.22
            ElseIf TaxableIncome <= 364200 Then
                Tax = 32580 + (TaxableIncome - 190750) * 0.24
            ElseIf TaxableIncome <= 462500 Then
                Tax = 74208 + (TaxableIncome - 364200) * 0.32
            ElseIf TaxableIncome <= 693750 Then
                Tax = 105664 + (TaxableIncome - 462500) * 0.35
            Else
                Tax = 186601.25 + (TaxableIncome - 693750) * 0.37
            End If
            
        ' Add other filing statuses as needed
    End Select
    
    CalculateFederalTax = Tax
End Function

Function CalculateStateTax(TaxableIncome As Double, State As String) As Double
    ' Calculate state income tax
    Dim StateTax As Double
    Dim StateRate As Double
    Dim StateDeduction As Double
    
    ' Look up state information
    StateRate = Application.WorksheetFunction.VLookup(State, _
                Worksheets("State Calculations").Range("A5:E60"), 2, False)
    StateDeduction = Application.WorksheetFunction.VLookup(State, _
                    Worksheets("State Calculations").Range("A5:E60"), 3, False)
    
    ' Calculate state tax
    If StateRate > 0 Then
        StateTax = Application.WorksheetFunction.Max(0, (TaxableIncome - StateDeduction) * StateRate)
    Else
        StateTax = 0 ' No state income tax
    End If
    
    CalculateStateTax = StateTax
End Function

Function CalculateSafeHarbor() As Double
    ' Calculate safe harbor amount
    Dim PriorYearTax As Double
    Dim PriorYearAGI As Double
    Dim CurrentYearTax As Double
    Dim SafeHarbor1 As Double ' 100% of prior year
    Dim SafeHarbor2 As Double ' 110% of prior year (if AGI > $150k)
    Dim SafeHarbor3 As Double ' 90% of current year
    
    ' Get data
    PriorYearTax = Worksheets("Input Data").Range("B18").Value
    PriorYearAGI = Worksheets("Input Data").Range("B17").Value
    CurrentYearTax = Worksheets("Calculations").Range("A15").Value
    
    ' Calculate safe harbor options
    SafeHarbor1 = PriorYearTax
    If PriorYearAGI > 150000 Then
        SafeHarbor2 = PriorYearTax * 1.1
    Else
        SafeHarbor2 = PriorYearTax
    End If
    SafeHarbor3 = CurrentYearTax * 0.9
    
    ' Return the minimum (safest option)
    CalculateSafeHarbor = Application.WorksheetFunction.Min(SafeHarbor1, SafeHarbor2, SafeHarbor3)
End Function

